---
layout: layouts/base.njk
permalink: /dispatch/
pageTitle: Dispatch
description: Shape a Thingy-authored archive Dispatch and have it sent to your email.
---

<section class="thingy-page dispatch-shell-page">
  <div class="thingy-app-shell dispatch-shell is-booting" id="dispatch-shell">
    <aside class="rail" aria-label="Thingy Dispatch">
      <div class="rail-top">
        <a class="rail-brand" href="/" aria-label="Thingy home" data-tinylytics-event="network.home" data-tinylytics-event-value="thingy">
          <img class="rail-mark" src="/img/thingy.png?v={{ site.assetVersion }}" alt="" width="1022" height="1022" loading="eager">
        </a>
      </div>

      <nav class="rail-surface-switch" aria-label="Thingy surfaces">
        <a href="/chat/">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"></path></svg>
          <span>Chat</span>
        </a>
        <a class="is-active" href="/dispatch/" aria-current="page">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16v16H4z"></path><path d="M8 9h8"></path><path d="M8 13h6"></path><path d="M8 17h4"></path></svg>
          <span>Dispatch</span>
        </a>
      </nav>

      <button class="rail-newchat dispatch-new" type="button" id="dispatch-new" data-tinylytics-event="dispatch.new" title="New Dispatch">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14"></path></svg>
        <span class="label">New Dispatch</span>
      </button>

      <div class="rail-body">
        <p class="rail-recents-label">Dispatches</p>
        <div class="rail-recents dispatch-recents" id="dispatch-recents" role="list" hidden></div>
        <p class="rail-empty" id="dispatch-empty">Shape a Dispatch and it will stay here until it is sent.</p>
      </div>

      <div class="rail-account">
        <button class="rail-account-btn" id="dispatch-account-btn" type="button" aria-haspopup="true" aria-expanded="false">
          <span class="rail-avatar" id="dispatch-account-avatar" aria-hidden="true">T</span>
          <span class="rail-account-meta">
            <span class="rail-account-email" id="dispatch-account-email">Signed in</span>
            <span class="rail-account-sub" id="dispatch-account-sub">Weekly Thing reader</span>
          </span>
        </button>
      </div>
    </aside>

    <section class="thingy-conversation dispatch-conversation" aria-label="Thingy Dispatch">
      <div class="mobile-chatbar" id="dispatch-mobilebar" aria-label="Dispatch">
        <a class="mobile-chatbar-circle" href="/chat/" aria-label="Switch to Chat" title="Switch to Chat">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 18l-6-6 6-6"></path></svg>
        </a>
        <div class="mobile-chatbar-title">
          <span id="dispatch-mobile-title">Dispatch</span>
        </div>
        <div class="mobile-chatbar-actions">
          <button class="mobile-chatbar-action" id="dispatch-mobile-new" type="button" aria-label="New Dispatch" title="New Dispatch">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14"></path></svg>
          </button>
        </div>
      </div>

      <div class="dispatch-chat" id="dispatch-app" hidden>
        <div class="thingy-chat-scroll dispatch-scroll">
          <div class="librarian-messages dispatch-messages" id="dispatch-messages" aria-live="polite"></div>
        </div>

        <div class="thingy-composer-zone dispatch-composer-zone">
          <div class="dispatch-actions" id="dispatch-actions" hidden></div>
          <form class="librarian-form librarian-question-form thingy-input composer-box dispatch-composer" id="dispatch-form">
            <label for="dispatch-input" class="sr-only">Message Thingy about this Dispatch</label>
            <textarea id="dispatch-input" rows="1" maxlength="1200" required placeholder="Tell Thingy what this Dispatch should explore..."></textarea>
            <div class="composer-toolbar">
              <span class="dispatch-status" id="dispatch-status" aria-live="polite"></span>
              <span class="composer-spacer"></span>
              <span class="composer-count" id="dispatch-count">0 / 1200</span>
              <button type="submit" class="composer-send" aria-label="Send to Thingy" title="Send to Thingy" data-tinylytics-event="dispatch.message">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 19V5"></path>
                  <path d="m5 12 7-7 7 7"></path>
                </svg>
              </button>
            </div>
          </form>
          <p class="thingy-ai-note">Dispatches are written by Thingy from Jamie&rsquo;s public archive, then sent by email when you generate them.</p>
        </div>
      </div>
    </section>
  </div>
</section>

<script>
  window.ThingyConfig = {
    librarianApiUrl: "{{ site.librarianApiUrl }}"
  };
</script>
<script src="/js/thingy-session.js?v={{ site.assetVersion }}"></script>
<script src="/js/thingy-dispatch.js?v={{ site.assetVersion }}"></script>

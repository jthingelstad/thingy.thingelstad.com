{
  "name": "thingy-web",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Thingy web app — thin client of the Librarian API.",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "serve": "vite --host 0.0.0.0",
    "clean": "rm -rf _site",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"tests/**/*.mjs\" \"scripts/**/*.mjs\" \"*.{js,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\" \"tests/**/*.mjs\" \"scripts/**/*.mjs\" \"*.{js,json}\"",
    "lint": "eslint . --max-warnings 0",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "knip": "knip --no-config-hints --include files,dependencies,unlisted",
    "qa:real": "node scripts/qa-real-api.mjs",
    "smoke": "node scripts/smoke-browser.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.5",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "knip": "^6.21.0",
    "playwright": "^1.61.1",
    "prettier": "^3.8.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "@preact/signals": "^2.9.2",
    "lucide-static": "^1.21.0",
    "preact": "^10.29.3"
  }
}

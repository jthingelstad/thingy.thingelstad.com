---
layout: layouts/base.njk
pageTitle: Thingy
description: Ask Thingy to find and synthesize writing from across Jamie Thingelstad's archive.
permalink: "/"
---
<section class="thingy-page">
  <div class="thingy-app-shell">
    <aside class="thingy-rail" aria-label="Thingy controls">
      <div class="thingy-rail-brand">
        <div class="thingy-card-avatar" aria-hidden="true">
          <img src="/img/thingy.png" alt="" width="1022" height="1022" loading="eager">
        </div>
        <div>
          <p class="thingy-card-name">Thingy</p>
          <p class="thingy-card-status"><span class="thingy-dot" aria-hidden="true"></span>Archive online</p>
        </div>
      </div>

      <div class="thingy-rail-section thingy-rail-intro">
        <p class="thingy-rail-kicker">Jamie&rsquo;s archive agent</p>
        <p>Ask across the newsletter, blog, and podcast. Thingy will only use the sources that are switched on.</p>
      </div>

      <fieldset class="librarian-scope-control thingy-source-rack" aria-label="Source scope">
        <legend>Sources</legend>
        <label class="thingy-source-switch thingy-source-wt">
          <input type="checkbox" name="scope" value="weekly_thing" checked>
          <span class="thingy-led" aria-hidden="true"></span>
          <span class="thingy-source-text">
            <strong>Weekly Thing</strong>
            <small>Issues, links, FAQ</small>
          </span>
        </label>
        <label class="thingy-source-switch thingy-source-blog">
          <input type="checkbox" name="scope" value="blog" checked>
          <span class="thingy-led" aria-hidden="true"></span>
          <span class="thingy-source-text">
            <strong>Blog</strong>
            <small>thingelstad.com</small>
          </span>
        </label>
        <label class="thingy-source-switch thingy-source-podcast">
          <input type="checkbox" name="scope" value="podcast" checked>
          <span class="thingy-led" aria-hidden="true"></span>
          <span class="thingy-source-text">
            <strong>Another Thing</strong>
            <small>Podcast transcripts</small>
          </span>
        </label>
        <p class="thingy-source-error" id="librarian-source-error" aria-live="polite"></p>
      </fieldset>

      <div class="thingy-rail-section thingy-rail-links">
        <p class="thingy-rail-kicker">Network</p>
        <a href="https://www.thingelstad.com/" data-tinylytics-event="network.visit" data-tinylytics-event-value="thingelstad">thingelstad.com</a>
        <a href="https://weekly.thingelstad.com/" data-tinylytics-event="network.visit" data-tinylytics-event-value="weekly">Weekly Thing</a>
        <a href="https://another.thingelstad.com/" data-tinylytics-event="network.visit" data-tinylytics-event-value="another">Another Thing</a>
      </div>

      <div class="thingy-rail-actions">
        <button type="button" id="librarian-clear-chat" class="thingy-card-tool" data-tinylytics-event="librarian.clear">New chat</button>
        <button type="button" id="librarian-logout" class="thingy-card-tool">Forget me</button>
      </div>

      <div class="thingy-rail-foot">
        <p>Thingy quotes from real sources. Verify before quoting elsewhere.</p>
        <p class="thingy-stats">
          <span class="thingy-stats-label">Public traffic</span>
          <span class="tinylytics_hits"></span> views
          <span class="thingy-stats-sep" aria-hidden="true">&middot;</span>
          <span class="tinylytics_countries"></span>
        </p>
        <button type="button" class="thingy-kudos tinylytics_kudos" data-path="/" aria-label="Send kudos to Thingy"></button>
      </div>
    </aside>

    <section class="thingy-conversation" aria-label="Thingy chat">
      <div class="librarian-auth thingy-auth" id="librarian-auth">
        <form class="librarian-form" id="librarian-auth-form">
          <p class="thingy-auth-title">Enter Thingy</p>
          <label for="librarian-email">Email address</label>
          <div class="librarian-auth-row">
            <input id="librarian-email" name="email" type="email" autocomplete="email" required class="subscribe-input">
            <button type="submit" id="librarian-auth-submit" data-tinylytics-event="librarian.auth_submit">Enter</button>
          </div>
          <span class="subscribe-error librarian-email-error" id="librarian-email-error" aria-live="polite"></span>
          <p class="form-message" id="librarian-auth-message" aria-live="polite"></p>
          <div class="librarian-auth-actions" id="librarian-auth-actions" hidden>
            <button type="button" id="librarian-add-subscriber" hidden>Add me</button>
            <button type="button" id="librarian-resend-confirmation" hidden>Resend confirmation email</button>
          </div>
          <p class="form-note">Thingy is available to Weekly Thing readers. Enter your email above and Thingy will help you subscribe if needed.</p>
        </form>
      </div>

      <div class="librarian-chat thingy-chat" id="librarian-chat" hidden>
        <div class="thingy-chat-scroll">
          <div class="thingy-chat-welcome" aria-hidden="true">
            <p class="eyebrow">Public Archive &middot; Beta</p>
            <h1 class="thingy-h1">Ask <em>Thingy</em>.</h1>
          </div>
          <div class="librarian-messages" id="librarian-messages" aria-live="polite"></div>
          <div class="librarian-prompts" id="librarian-prompts" aria-label="Suggested questions" hidden></div>
        </div>

        <form class="librarian-form librarian-question-form thingy-input" id="librarian-question-form">
          <label for="librarian-question" class="sr-only">Ask Thingy</label>
          <textarea id="librarian-question" name="message" rows="2" required maxlength="1200" placeholder="Ask Thingy anything about the archive&hellip;" aria-describedby="librarian-question-count librarian-source-error"></textarea>
          <div class="librarian-question-meta">
            <span id="librarian-question-count">0 / 1200</span>
          </div>
          <div class="librarian-question-actions">
            <button type="submit" data-tinylytics-event="librarian.question_submit">Ask</button>
          </div>
        </form>
      </div>
    </section>
  </div>

  <div class="librarian-beta-overlay" id="librarian-beta-overlay" hidden>
    <div class="librarian-beta-modal" role="dialog" aria-modal="true" aria-labelledby="librarian-beta-title" aria-describedby="librarian-beta-description">
      <p class="eyebrow">Private Beta</p>
      <h2 id="librarian-beta-title">Thingy is experimental</h2>
      <p id="librarian-beta-description">Thingy can search and synthesize Jamie&rsquo;s published archive, but it may miss things, read sources too narrowly, or cite an imperfect set of references. It only uses archive sources and should show references when it can.</p>
      <p>Beta conversations may be logged and reviewed to improve Thingy. Please treat this as an early preview and send along answers that feel especially useful, vague, weird, or wrong.</p>
      <button type="button" id="librarian-beta-close">I understand</button>
    </div>
  </div>

</section>

<script>
  (() => {
    const apiBaseSource = window.WEEKLY_THING_LIBRARIAN_API === undefined ? '{{ site.librarianApiUrl }}' : window.WEEKLY_THING_LIBRARIAN_API;
    const streamBaseSource = window.WEEKLY_THING_LIBRARIAN_STREAM_API === undefined ? '{{ site.librarianStreamUrl }}' : window.WEEKLY_THING_LIBRARIAN_STREAM_API;
    const apiBase = String(apiBaseSource || '').replace(/\/$/, '');
    const streamBase = String(streamBaseSource || '').replace(/\/$/, '');
    const authPanel = document.getElementById('librarian-auth');
    const chatPanel = document.getElementById('librarian-chat');
    const authForm = document.getElementById('librarian-auth-form');
    const questionForm = document.getElementById('librarian-question-form');
    const emailInput = document.getElementById('librarian-email');
    const emailError = document.getElementById('librarian-email-error');
    const authButton = document.getElementById('librarian-auth-submit');
    const authMessage = document.getElementById('librarian-auth-message');
    const authActions = document.getElementById('librarian-auth-actions');
    const addSubscriberButton = document.getElementById('librarian-add-subscriber');
    const resendConfirmationButton = document.getElementById('librarian-resend-confirmation');
    const logoutButton = document.getElementById('librarian-logout');
    const clearChatButton = document.getElementById('librarian-clear-chat');
    const questionInput = document.getElementById('librarian-question');
    const questionButton = questionForm.querySelector('button[type="submit"]');
    const scopeInputs = Array.from(document.querySelectorAll('input[name="scope"]'));
    const sourceError = document.getElementById('librarian-source-error');
    const questionCount = document.getElementById('librarian-question-count');
    const messages = document.getElementById('librarian-messages');
    const prompts = document.getElementById('librarian-prompts');
    const betaOverlay = document.getElementById('librarian-beta-overlay');
    const betaCloseButton = document.getElementById('librarian-beta-close');
    const storageKey = 'weeklyThingLibrarianToken';
    const betaNoticeStorageKey = 'weeklyThingLibrarianBetaNotice';
    const maxHistoryMessages = 8;
    const maxHistoryChars = 4000;
    const maxQuestionChars = Number(questionInput.getAttribute('maxlength') || '1200');
    const starterMessageHtml = '';
    const sourceOrder = ['weekly_thing', 'blog', 'podcast'];
    const starterQuestions = {
      discovery: [
        'Give me a tour of what Jamie publishes across the archive.',
        'What are the big themes that connect the blog, newsletter, and podcast?',
        'Find a good place to start if I care about personal knowledge systems.',
        'What has Jamie returned to again and again over the years?',
        'Show me something recent and something older on the same idea.',
        'Pick a surprising thread that crosses more than one source.',
        'What parts of the archive feel most personal?',
        'Where does Jamie explain how he works?',
        'Find a useful answer hiding in an old post or issue.',
        'What should I read first if I am new here?'
      ],
      topical: [
        'What has Jamie said about AI, and how has it changed?',
        'Find writing about owning your content and the IndieWeb.',
        'What does the archive say about newsletters as a medium?',
        'Show me Jamie on leadership, teams, and operating systems.',
        'Find posts and issues about Minneapolis or Minnesota.',
        'What tools does Jamie keep recommending?',
        "Trace Jamie's thinking about automation.",
        'Find writing about family rituals and annual traditions.',
        'What has Jamie written about RSS and open web plumbing?',
        'Show me the thread on attention, focus, and intentional technology.',
        "Find recommendations for books that shaped Jamie's thinking.",
        'What personal projects show up repeatedly?',
        'Where does Jamie talk about community and belonging?',
        'Find anything about static sites, Eleventy, or publishing workflows.',
        'What does Jamie say about craft, quality, and maintenance?',
        'Show me examples of long-term thinking in the archive.',
        'Find travel writing or trip notes.',
        'What does the podcast add that the written archive does not?',
        'Find the best context for Things 4 Good.',
        'Where has Jamie contradicted or revised himself?'
      ],
      playful: [
        'Build me a reading list for tonight.',
        'Give me three links worth my time.',
        'Surprise me with a connection I would not expect.',
        'What would Jamie put in a starter pack for this archive?',
        'Find a delightful rabbit hole.',
        'Quote me something useful from the archive.',
        'What is the most Jamie-shaped idea in here?',
        'Give me one practical takeaway and one weird one.',
        'What should I ask Thingy next?',
        'Quote me something from the archive.',
        "Tell me something I'd find interesting."
      ]
    };
    const eventSink = document.createElement('button');
    eventSink.type = 'button';
    eventSink.hidden = true;
    eventSink.setAttribute('aria-hidden', 'true');
    document.body.appendChild(eventSink);
    const pendingTinylyticsEvents = [];
    let tinylyticsReady = false;
    let answerInFlight = false;
    let conversationHistory = [];
    let feedbackStatusTimer = 0;
    const emailRe = /^[a-zA-Z0-9.!#$%&'*+\/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)+$/;

    const params = new URLSearchParams(window.location.search);
    const email = normalizeEmail(params.get('email'));
    const initialPrompt = normalizeInitialPrompt(params.get('prompt'));
    const initialScope = normalizeScopeParam(params.get('scope')) || normalizeScopeParam(params.get('corpus'));
    let activeScope = initialScope || 'all';
    let initialPromptSubmitted = false;
    if (email) emailInput.value = email;

    function normalizeEmail(value) {
      return String(value || '').trim();
    }

    function normalizeInitialPrompt(value) {
      return String(value || '').trim().slice(0, maxQuestionChars);
    }

    // URL scoping narrows shared links; the visible selector uses the same values.
    function normalizeScopeParam(value) {
      const raw = String(value || '').trim().toLowerCase();
      if (!raw) return '';
      const normalized = raw.replace(/[\s-]+/g, '_').replace(/^_+|_+$/g, '');
      if (normalized === 'all' || normalized === 'everything') return 'all';
      if (normalized === 'both') return 'both';
      if (normalized === 'weekly_thing_podcast' || normalized === 'wt_podcast') return 'weekly_thing_podcast';
      if (normalized === 'blog_podcast' || normalized === 'podcast_blog') return 'blog_podcast';

      const tokens = raw.split(/[,+|]/)
        .map((part) => part.trim().replace(/[\s-]+/g, '_').replace(/^_+|_+$/g, ''))
        .filter(Boolean);
      const mapped = new Set();
      for (const token of tokens.length ? tokens : [normalized]) {
        if (token === 'blog' || token === 'thingelstad' || token === 'thingelstad_com') mapped.add('blog');
        if (token === 'podcast' || token === 'podcasts' || token === 'another_thing' || token === 'anotherthing' || token === 'another') mapped.add('podcast');
        if (token === 'weekly_thing' || token === 'wt' || token === 'weeklything' || token === 'issues' || token === 'archive' || token === 'newsletter') mapped.add('weekly_thing');
      }
      if (mapped.size === 3) return 'all';
      if (mapped.has('weekly_thing') && mapped.has('blog') && mapped.size === 2) return 'both';
      if (mapped.has('weekly_thing') && mapped.has('podcast') && mapped.size === 2) return 'weekly_thing_podcast';
      if (mapped.has('blog') && mapped.has('podcast') && mapped.size === 2) return 'blog_podcast';
      if (mapped.size === 1) return Array.from(mapped)[0];
      return '';
    }

    function validateEmail() {
      const value = emailInput.value.trim();
      if (!value) {
        emailError.textContent = '';
        emailInput.classList.remove('invalid');
        authButton.disabled = false;
        return true;
      }
      if (emailRe.test(value)) {
        emailError.textContent = '';
        emailInput.classList.remove('invalid');
        authButton.disabled = false;
        return true;
      }
      emailError.textContent = 'Please enter a valid email address';
      emailInput.classList.add('invalid');
      authButton.disabled = true;
      return false;
    }

    function token() {
      return window.localStorage.getItem(storageKey);
    }

    function currentScope() {
      return scopeForSources(selectedSources());
    }

    function selectedSources() {
      return scopeInputs.filter((input) => input.checked).map((input) => input.value);
    }

    function scopeForSources(sources) {
      const selected = sourceOrder.filter((source) => sources.includes(source));
      if (selected.length === 3) return 'all';
      if (selected.length === 1) return selected[0];
      if (selected.includes('weekly_thing') && selected.includes('blog') && selected.length === 2) return 'both';
      if (selected.includes('weekly_thing') && selected.includes('podcast') && selected.length === 2) return 'weekly_thing_podcast';
      if (selected.includes('blog') && selected.includes('podcast') && selected.length === 2) return 'blog_podcast';
      return '';
    }

    function sourcesForScope(scope) {
      switch (normalizeScopeParam(scope) || 'all') {
        case 'weekly_thing':
          return ['weekly_thing'];
        case 'blog':
          return ['blog'];
        case 'podcast':
          return ['podcast'];
        case 'both':
          return ['weekly_thing', 'blog'];
        case 'weekly_thing_podcast':
          return ['weekly_thing', 'podcast'];
        case 'blog_podcast':
          return ['blog', 'podcast'];
        case 'all':
        default:
          return [...sourceOrder];
      }
    }

    function sourceCount() {
      return selectedSources().length;
    }

    function setActiveScope(value, options = {}) {
      const sources = sourcesForScope(value);
      scopeInputs.forEach((input) => {
        input.checked = sources.includes(input.value);
      });
      activeScope = scopeForSources(sources);
      if (options.track !== false) trackTinylyticsEvent('librarian.scope_change', activeScope);
      updateQuestionState();
    }

    setActiveScope(activeScope, { track: false });

    function showBetaNotice() {
      if (window.sessionStorage.getItem(betaNoticeStorageKey) === 'dismissed') return;
      betaOverlay.hidden = false;
      document.body.classList.add('librarian-beta-open');
      betaCloseButton.focus();
      trackTinylyticsEvent('librarian.beta_notice_shown');
    }

    function hideBetaNotice(options = {}) {
      const remember = options.remember !== false;
      const focusQuestion = options.focusQuestion !== false;
      betaOverlay.hidden = true;
      document.body.classList.remove('librarian-beta-open');
      if (remember) window.sessionStorage.setItem(betaNoticeStorageKey, 'dismissed');
      if (focusQuestion) questionInput.focus();
      if (remember) trackTinylyticsEvent('librarian.beta_notice_dismissed');
      maybeSubmitInitialPrompt();
    }

    function setToken(value, message, options = {}) {
      window.localStorage.setItem(storageKey, value);
      authPanel.hidden = true;
      chatPanel.hidden = false;
      hideAuthActions();
      if (message) addMessage('system', `<p>${escapeHtml(message)}</p>`);
      loadPrompts();
      if (options.skipBetaNotice) {
        hideBetaNotice({ remember: false, focusQuestion: false });
      } else {
        showBetaNotice();
      }
      if (betaOverlay.hidden) questionInput.focus();
      maybeSubmitInitialPrompt();
    }

    function clearToken() {
      window.localStorage.removeItem(storageKey);
      hideBetaNotice({ remember: false, focusQuestion: false });
      conversationHistory = [];
      chatPanel.hidden = true;
      authPanel.hidden = false;
      prompts.hidden = true;
      prompts.innerHTML = '';
      hideAuthActions();
      setAuthMessage('');
      emailInput.focus();
    }

    function addMessage(kind, html) {
      const item = document.createElement('div');
      item.className = `librarian-message librarian-message-${kind}`;
      item.innerHTML = html;
      messages.appendChild(item);
      item.scrollIntoView({ block: 'end', behavior: 'smooth' });
      return item;
    }

    function autoSizeQuestionInput() {
      questionInput.style.height = 'auto';
      questionInput.style.height = `${Math.min(questionInput.scrollHeight, 240)}px`;
    }

    function updateQuestionState() {
      const length = questionInput.value.length;
      const hasSources = sourceCount() > 0;
      questionCount.textContent = `${length} / ${maxQuestionChars}`;
      questionCount.classList.toggle('warning', length > maxQuestionChars * 0.9);
      if (sourceError) sourceError.textContent = hasSources ? '' : 'Switch on at least one source.';
      questionForm.classList.toggle('is-busy', answerInFlight);
      questionButton.disabled = answerInFlight || !hasSources || !questionInput.value.trim() || length > maxQuestionChars;
      questionButton.textContent = answerInFlight ? 'Asking...' : 'Ask';
      clearChatButton.disabled = answerInFlight;
      scopeInputs.forEach((input) => { input.disabled = answerInFlight; });
      autoSizeQuestionInput();
    }

    function setAuthMessage(message) {
      authMessage.textContent = message || '';
    }

    function hideAuthActions() {
      authActions.hidden = true;
      addSubscriberButton.hidden = true;
      resendConfirmationButton.hidden = true;
    }

    function showAuthAction(action) {
      authActions.hidden = false;
      addSubscriberButton.hidden = action !== 'subscribe';
      resendConfirmationButton.hidden = action !== 'resend_confirmation';
    }

    function sendTinylyticsEvent(name, value) {
      if (!name || !('{{ site.tinylyticsId }}')) return;
      eventSink.setAttribute('data-tinylytics-event', name);
      if (value) {
        eventSink.setAttribute('data-tinylytics-event-value', value);
      } else {
        eventSink.removeAttribute('data-tinylytics-event-value');
      }
      eventSink.click();
    }

    function flushTinylyticsEvents() {
      tinylyticsReady = true;
      while (pendingTinylyticsEvents.length) {
        const event = pendingTinylyticsEvents.shift();
        sendTinylyticsEvent(event.name, event.value);
      }
    }

    function trackTinylyticsEvent(name, value) {
      if (tinylyticsReady) {
        sendTinylyticsEvent(name, value);
      } else {
        pendingTinylyticsEvents.push({ name, value });
      }
    }

    window.addEventListener('tinylytics:loaded', flushTinylyticsEvents, { once: true });

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
      })[char]);
    }

    function safeMarkdownUrl(url) {
      const value = String(url || '').trim();
      if (/^https?:/i.test(value) || /^mailto:/i.test(value)) return escapeHtml(value);
      if (/^\/archive\//i.test(value)) return escapeHtml(`https://weekly.thingelstad.com${value}`);
      if (/^\//.test(value)) return escapeHtml(value);
      return '#';
    }

    function citationMap(citations) {
      const map = new Map();
      (citations || []).forEach((citation) => {
        const issue = String(citation.issue_number || '').trim();
        if (issue && citation.url && !map.has(issue)) map.set(issue, citation);
      });
      return map;
    }

    function citationTitle(citation) {
      const parts = [`WT${citation.issue_number}: ${citation.subject || 'Weekly Thing'}`];
      if (citation.publish_date) parts.push(String(citation.publish_date).slice(0, 10));
      if (citation.section) parts.push(citation.section);
      return parts.join(' | ');
    }

    function linkIssueReferences(html, citationsByIssue) {
      if (!citationsByIssue || citationsByIssue.size === 0) return html;
      return html.split(/(<[^>]+>)/g).map((part) => {
        if (part.startsWith('<')) return part;
        return part.replace(/(^|[^\w&])(?:WT|#)(\d{1,4})\b/g, (match, prefix, issue) => {
          const citation = citationsByIssue.get(issue);
          if (!citation) return match;
          return `${prefix}<a href="${safeMarkdownUrl(citation.url)}" title="${escapeHtml(citationTitle(citation))}" data-tinylytics-event="librarian.source_click" data-tinylytics-event-value="${escapeHtml(issue)}">WT${escapeHtml(issue)}</a>`;
        });
      }).join('');
    }

    function renderInlineMarkdown(text, citationsByIssue) {
      let html = escapeHtml(text);
      const code = [];
      html = html.replace(/`([^`]+)`/g, (_, value) => {
        const token = `@@CODE${code.length}@@`;
        code.push(`<code>${value}</code>`);
        return token;
      });
      html = html.replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, (_, label, url) => `<a href="${safeMarkdownUrl(url)}">${label}</a>`);
      html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
      html = html.replace(/__([^_]+)__/g, '<strong>$1</strong>');
      html = html.replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
      html = html.replace(/(^|[^_])_([^_\n]+)_/g, '$1<em>$2</em>');
      html = linkIssueReferences(html, citationsByIssue);
      code.forEach((value, index) => {
        html = html.replace(`@@CODE${index}@@`, value);
      });
      return html;
    }

    function renderMarkdown(markdown, citations = []) {
      const text = String(markdown || '').trim();
      if (!text) return '<p>Thingy is looking through the archive...</p>';
      const citationsByIssue = citationMap(citations);
      const lines = text.split(/\r?\n/);
      const html = [];
      let paragraph = [];
      let listType = null;
      let blockquote = [];

      function flushParagraph() {
        if (!paragraph.length) return;
        html.push(`<p>${renderInlineMarkdown(paragraph.join(' '), citationsByIssue)}</p>`);
        paragraph = [];
      }

      function flushList() {
        if (!listType) return;
        html.push(`</${listType}>`);
        listType = null;
      }

      function flushBlockquote() {
        if (!blockquote.length) return;
        html.push(`<blockquote>${renderMarkdown(blockquote.join('\n'), citations)}</blockquote>`);
        blockquote = [];
      }

      function openList(type) {
        if (listType === type) return;
        flushParagraph();
        flushBlockquote();
        flushList();
        listType = type;
        html.push(`<${type}>`);
      }

      function isTableRow(value) {
        const trimmed = String(value || '').trim();
        return trimmed.startsWith('|') && trimmed.endsWith('|') && trimmed.slice(1, -1).includes('|');
      }

      function isTableSeparator(value) {
        if (!isTableRow(value)) return false;
        return tableCells(value).every((cell) => /^:?-{3,}:?$/.test(cell));
      }

      function tableCells(value) {
        return String(value || '').trim().replace(/^\|/, '').replace(/\|$/, '').split('|').map((cell) => cell.trim());
      }

      function renderTableCell(tag, value) {
        return `<${tag}>${renderInlineMarkdown(value, citationsByIssue)}</${tag}>`;
      }

      for (let index = 0; index < lines.length; index += 1) {
        const line = lines[index];
        const trimmed = line.trim();
        if (!trimmed) {
          flushParagraph();
          flushBlockquote();
          flushList();
          continue;
        }

        if (isTableRow(trimmed) && isTableSeparator(lines[index + 1])) {
          flushParagraph();
          flushBlockquote();
          flushList();
          const headers = tableCells(trimmed);
          index += 2;
          const rows = [];
          while (index < lines.length && isTableRow(lines[index])) {
            rows.push(tableCells(lines[index]));
            index += 1;
          }
          index -= 1;
          html.push('<div class="librarian-table-wrap"><table>');
          html.push(`<thead><tr>${headers.map((cell) => renderTableCell('th', cell)).join('')}</tr></thead>`);
          html.push('<tbody>');
          for (const row of rows) {
            const normalized = headers.map((_, cellIndex) => row[cellIndex] || '');
            html.push(`<tr>${normalized.map((cell) => renderTableCell('td', cell)).join('')}</tr>`);
          }
          html.push('</tbody></table></div>');
          continue;
        }

        const heading = /^(#{2,4})\s+(.+)$/.exec(trimmed);
        if (heading) {
          flushParagraph();
          flushBlockquote();
          flushList();
          const level = heading[1].length;
          html.push(`<h${level}>${renderInlineMarkdown(heading[2], citationsByIssue)}</h${level}>`);
          continue;
        }

        const unordered = /^[-*]\s+(.+)$/.exec(trimmed);
        if (unordered) {
          openList('ul');
          html.push(`<li>${renderInlineMarkdown(unordered[1], citationsByIssue)}</li>`);
          continue;
        }

        const ordered = /^\d+\.\s+(.+)$/.exec(trimmed);
        if (ordered) {
          openList('ol');
          html.push(`<li>${renderInlineMarkdown(ordered[1], citationsByIssue)}</li>`);
          continue;
        }

        const quote = /^>\s?(.+)$/.exec(trimmed);
        if (quote) {
          flushParagraph();
          flushList();
          blockquote.push(quote[1]);
          continue;
        }

        flushList();
        flushBlockquote();
        paragraph.push(trimmed);
      }

      flushParagraph();
      flushBlockquote();
      flushList();
      return html.join('');
    }

    function renderAnswer(answer, citations = []) {
      return renderMarkdown(answer, citations);
    }

    function setFeedbackState(container, reaction) {
      container.querySelectorAll('button[data-reaction]').forEach((button) => {
        const selected = button.dataset.reaction === reaction;
        button.classList.toggle('selected', selected);
        button.setAttribute('aria-pressed', selected ? 'true' : 'false');
      });
    }

    async function submitFeedback(requestId, reaction, container) {
      const status = container.querySelector('.librarian-feedback-status');
      container.querySelectorAll('button[data-reaction]').forEach((button) => {
        button.disabled = true;
      });
      if (status) status.textContent = 'Saving...';
      try {
        const data = await postStreamJson('/feedback', {
          request_id: requestId,
          reaction
        }, { authorization: `Bearer ${token()}` });
        setFeedbackState(container, data.reaction || reaction);
        if (status) status.textContent = 'Saved';
        window.clearTimeout(feedbackStatusTimer);
        feedbackStatusTimer = window.setTimeout(() => {
          if (status && status.textContent === 'Saved') status.textContent = '';
        }, 1800);
        trackTinylyticsEvent('librarian.feedback_submit', data.reaction || reaction);
      } catch (error) {
        if (status) status.textContent = 'Could not save';
        trackTinylyticsEvent('librarian.feedback_error', error.requestId ? 'server' : 'client');
      } finally {
        container.querySelectorAll('button[data-reaction]').forEach((button) => {
          button.disabled = false;
        });
      }
    }

    function buildSharePromptUrl(prompt, scope) {
      const url = new URL('/', window.location.origin);
      url.searchParams.set('prompt', prompt);
      // Always encode the scope so a shared link reproduces the exact corpus
      // boundary used for this turn.
      url.searchParams.set('scope', scope || 'all');
      return url.toString();
    }

    function addShareControls(messageElement, prompt, scope) {
      if (!prompt) return;
      const para = messageElement.querySelector('p');
      if (!para) return;
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'librarian-share-anchor';
      button.setAttribute('aria-label', 'Copy a sharable link to this prompt');
      button.setAttribute('title', 'Share this prompt');
      button.textContent = '#';
      para.appendChild(document.createTextNode(' '));
      para.appendChild(button);
      let resetTimer = 0;
      function flash(text, kind) {
        button.textContent = text;
        button.dataset.kind = kind || '';
        window.clearTimeout(resetTimer);
        resetTimer = window.setTimeout(() => {
          button.textContent = '#';
          button.dataset.kind = '';
        }, 1500);
      }
      button.addEventListener('click', async (event) => {
        event.preventDefault();
        const shareUrl = buildSharePromptUrl(prompt, scope);
        if (typeof navigator.share === 'function') {
          try {
            await navigator.share({ title: 'Ask Thingy', text: prompt, url: shareUrl });
            trackTinylyticsEvent('librarian.share_native');
            return;
          } catch (error) {
            if (error && error.name === 'AbortError') return;
            // fall through to clipboard
          }
        }
        if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
          try {
            await navigator.clipboard.writeText(shareUrl);
            flash('✓', 'success');
            trackTinylyticsEvent('librarian.share_copy');
            return;
          } catch (error) { /* fall through */ }
        }
        flash('!', 'error');
      });
    }

    function addFeedbackControls(messageElement, requestId) {
      if (!requestId) return;
      const controls = document.createElement('div');
      controls.className = 'librarian-feedback';
      controls.innerHTML = `
        <span class="librarian-feedback-label">Was this useful?</span>
        <button type="button" data-reaction="up" aria-label="Thumbs up" aria-pressed="false" title="Thumbs up">&#128077;</button>
        <button type="button" data-reaction="down" aria-label="Thumbs down" aria-pressed="false" title="Thumbs down">&#128078;</button>
        <span class="librarian-feedback-status" aria-live="polite"></span>
      `;
      controls.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : event.target.parentElement;
        const button = target ? target.closest('button[data-reaction]') : null;
        if (!button || !controls.contains(button)) return;
        if (button.classList.contains('selected')) return;
        submitFeedback(requestId, button.dataset.reaction, controls);
      });
      messageElement.appendChild(controls);
    }

    async function postJson(path, payload, headers = {}) {
      if (!apiBase) throw new Error('Thingy has not been connected to the archive API yet.');
      const controller = new AbortController();
      const timeout = window.setTimeout(() => controller.abort(), 60000);
      const response = await fetch(`${apiBase}${path}`, {
        method: 'POST',
        headers: { 'content-type': 'application/json', ...headers },
        body: JSON.stringify(payload),
        signal: controller.signal
      }).catch((error) => {
        if (error.name === 'AbortError') {
          throw new Error('Thingy took too long to respond. Please try again.');
        }
        throw error;
      }).finally(() => {
        window.clearTimeout(timeout);
      });
      const requestId = response.headers.get('x-request-id');
      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        const message = data.error || 'Thingy is unavailable.';
        const error = new Error(requestId ? `${message} Reference: ${requestId}` : message);
        error.requestId = requestId;
        throw error;
      }
      return data;
    }

    async function postStreamJson(path, payload, headers = {}) {
      if (!streamBase) throw new Error('Thingy has not been connected to the archive stream API yet.');
      const controller = new AbortController();
      const timeout = window.setTimeout(() => controller.abort(), 60000);
      const response = await fetch(`${streamBase}${path}`, {
        method: 'POST',
        headers: { 'content-type': 'application/json', ...headers },
        body: JSON.stringify(payload),
        signal: controller.signal
      }).catch((error) => {
        if (error.name === 'AbortError') {
          throw new Error('Thingy took too long to respond. Please try again.');
        }
        throw error;
      }).finally(() => {
        window.clearTimeout(timeout);
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        const message = data.error || 'Thingy is unavailable.';
        const error = new Error(data.request_id ? `${message} Reference: ${data.request_id}` : message);
        error.requestId = data.request_id;
        throw error;
      }
      return data;
    }

    function compactHistory(history) {
      let chars = 0;
      const result = [];
      for (const item of history.slice(-maxHistoryMessages).reverse()) {
        const role = item.role === 'assistant' ? 'assistant' : item.role === 'user' ? 'user' : '';
        const content = String(item.content || '').trim().replace(/\s+/g, ' ').slice(0, 700);
        if (!role || !content) continue;
        chars += content.length;
        if (chars > maxHistoryChars) break;
        result.unshift({ role, content });
      }
      return result;
    }

    function rememberTurn(question, answer) {
      conversationHistory.push({ role: 'user', content: question });
      conversationHistory.push({ role: 'assistant', content: answer });
      conversationHistory = compactHistory(conversationHistory);
    }

    function clearConversation() {
      if (answerInFlight) return;
      conversationHistory = [];
      questionInput.value = '';
      messages.innerHTML = starterMessageHtml;
      updateQuestionState();
      loadPrompts();
      questionInput.focus();
      trackTinylyticsEvent('librarian.clear');
    }

    function hidePrompts() {
      prompts.classList.remove('librarian-prompts-loading');
      prompts.hidden = true;
      prompts.innerHTML = '';
    }

    function randomItem(items) {
      return items[Math.floor(Math.random() * items.length)];
    }

    function starterPromptSet() {
      return [
        randomItem(starterQuestions.discovery),
        randomItem(starterQuestions.topical),
        randomItem(starterQuestions.playful)
      ].map((question) => ({ label: question, question }));
    }

    function renderPrompts(promptItems) {
      if (!promptItems || !promptItems.length || answerInFlight) return;
      prompts.classList.remove('librarian-prompts-loading');
      prompts.innerHTML = promptItems.map((item, index) => {
        const question = escapeHtml(item.question || item.label || '');
        const label = escapeHtml(item.label || `Question ${index + 1}`);
        return `<button type="button" data-question="${question}" title="${question}" data-tinylytics-event="librarian.prompt_select" data-tinylytics-event-value="${index + 1}">${label}</button>`;
      }).join('');
      prompts.hidden = false;
    }

    function loadPrompts() {
      if (!token() || answerInFlight || (initialPrompt && !initialPromptSubmitted)) return;
      renderPrompts(starterPromptSet());
      trackTinylyticsEvent('librarian.prompts_loaded', 'static');
    }

    function maybeSubmitInitialPrompt() {
      if (!initialPrompt || initialPromptSubmitted || answerInFlight || !token()) return;
      if (!betaOverlay.hidden) return;
      initialPromptSubmitted = true;
      questionInput.value = initialPrompt;
      updateQuestionState();
      questionForm.requestSubmit();
    }

    function handleAuthResponse(data, options = {}) {
      if (data.token) {
        setToken(data.token, data.message, options);
        setAuthMessage('');
        trackTinylyticsEvent('librarian.auth_success', data.status || 'active');
        return;
      }
      if (data.status === 'not_found') {
        setAuthMessage(data.message || 'That email is not subscribed. Would you like to be added?');
        showAuthAction('subscribe');
        trackTinylyticsEvent('librarian.auth_not_found');
        return;
      }
      if (data.status === 'unconfirmed') {
        setAuthMessage(data.message || 'Please confirm your email before using Thingy.');
        showAuthAction('resend_confirmation');
        trackTinylyticsEvent('librarian.auth_unconfirmed');
        return;
      }
      if (data.status === 'subscribed') {
        setAuthMessage(data.message || 'Check your inbox to confirm your subscription before using Thingy.');
        hideAuthActions();
        trackTinylyticsEvent('librarian.auth_subscribe_success');
        return;
      }
      if (data.status === 'reminder_sent') {
        setAuthMessage(data.message || 'Confirmation email sent. Check your inbox.');
        hideAuthActions();
        trackTinylyticsEvent('librarian.auth_reminder_success');
        return;
      }
      setAuthMessage(data.message || 'I could not verify active subscriber access for that email.');
      hideAuthActions();
      trackTinylyticsEvent('librarian.auth_inactive');
    }

    function readAttribution() {
      try {
        if (typeof window.weeklyThingAttribution === 'function') {
          return window.weeklyThingAttribution() || undefined;
        }
      } catch (err) { /* ignore */ }
      return undefined;
    }

    async function submitAuthAction(action, button) {
      if (!validateEmail()) return;
      button.disabled = true;
      hideAuthActions();
      setAuthMessage(action === 'subscribe' ? 'Adding you to the Weekly Thing...' : 'Sending the confirmation email...');
      try {
        const payload = { email: emailInput.value, action, source: 'thingy' };
        if (action === 'subscribe' || action === 'resend_confirmation') {
          const attribution = readAttribution();
          if (attribution) payload.attribution = attribution;
        }
        const data = await postJson('/auth', payload);
        handleAuthResponse(data);
      } catch (error) {
        setAuthMessage(error.message);
        trackTinylyticsEvent('librarian.auth_error', error.requestId ? 'server' : 'client');
      } finally {
        button.disabled = false;
      }
    }

    async function submitAuthCheck(options = {}) {
      if (!validateEmail()) return false;
      authButton.disabled = true;
      hideAuthActions();
      setAuthMessage('Checking subscriber access...');
      try {
        const data = await postJson('/auth', { email: emailInput.value.trim(), action: 'check', source: 'thingy' });
        handleAuthResponse(data, options);
        return true;
      } catch (error) {
        setAuthMessage(error.message);
        trackTinylyticsEvent('librarian.auth_error', error.requestId ? 'server' : 'client');
        return false;
      } finally {
        authButton.disabled = false;
        validateEmail();
      }
    }

    async function postStreamingChat(message, pending, history, scope) {
      if (!streamBase) {
        throw new Error('Thingy has not been connected to the archive stream API yet.');
      }

      let answer = '';
      let citations = [];
      let requestId = '';
      const controller = new AbortController();
      const timeout = window.setTimeout(() => controller.abort(), 85000);
      const response = await fetch(`${streamBase}/chat`, {
        method: 'POST',
        headers: {
          'content-type': 'application/json',
          authorization: `Bearer ${token()}`
        },
        body: JSON.stringify({ message, history, scope }),
        signal: controller.signal
      }).catch((error) => {
        if (error.name === 'AbortError') {
          throw new Error('Thingy took too long to respond. Please try again.');
        }
        throw error;
      }).finally(() => {
        window.clearTimeout(timeout);
      });
      if (!response.ok || !response.body) {
        throw new Error('Thingy is unavailable.');
      }

      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      function applyEvent(eventName, data) {
        if (eventName === 'meta') {
          requestId = data.request_id || requestId;
        } else if (eventName === 'status') {
          answer = '';
          pending.classList.add('librarian-message-pending');
          pending.innerHTML = `<p class="librarian-status-line"><span class="librarian-thinking-dot"></span>${escapeHtml(data.message || 'Thingy is working...')}</p>`;
        } else if (eventName === 'answer_delta') {
          const wasEmpty = answer === '';
          answer += data.delta || '';
          if (wasEmpty) {
            answer = answer.replace(/^\s+/, '');
            while (pending.firstChild) pending.removeChild(pending.firstChild);
          }
          pending.classList.remove('librarian-message-pending');
          pending.innerHTML = renderAnswer(answer, citations);
          pending.scrollIntoView({ block: 'end', behavior: 'smooth' });
        } else if (eventName === 'citations') {
          citations = data.citations || [];
          pending.innerHTML = renderAnswer(answer, citations);
        } else if (eventName === 'error') {
          const error = new Error(data.error || 'Thingy is unavailable.');
          error.requestId = data.request_id || requestId;
          throw error;
        }
      }

      function consumeEvent(rawEvent) {
        const lines = rawEvent.split('\n');
        let eventName = 'message';
        const data = [];
        for (const line of lines) {
          if (line.startsWith('event:')) eventName = line.slice(6).trim();
          if (line.startsWith('data:')) data.push(line.slice(5).trimStart());
        }
        if (!data.length) return;
        applyEvent(eventName, JSON.parse(data.join('\n')));
      }

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        const events = buffer.split(/\n\n/);
        buffer = events.pop() || '';
        events.filter(Boolean).forEach(consumeEvent);
      }
      buffer += decoder.decode();
      if (buffer.trim()) consumeEvent(buffer);
      return { answer, citations, request_id: requestId };
    }

    authForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      await submitAuthCheck();
    });

    emailInput.addEventListener('input', () => {
      validateEmail();
      hideAuthActions();
    });

    addSubscriberButton.addEventListener('click', () => {
      submitAuthAction('subscribe', addSubscriberButton);
    });

    resendConfirmationButton.addEventListener('click', () => {
      submitAuthAction('resend_confirmation', resendConfirmationButton);
    });

    logoutButton.addEventListener('click', () => {
      clearToken();
      trackTinylyticsEvent('librarian.logout');
    });

    clearChatButton.addEventListener('click', clearConversation);

    betaCloseButton.addEventListener('click', hideBetaNotice);

    betaOverlay.addEventListener('click', (event) => {
      if (event.target === betaOverlay) hideBetaNotice();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !betaOverlay.hidden) hideBetaNotice();
    });

    async function submitQuestion() {
      if (answerInFlight) return;
      const message = questionInput.value.trim();
      if (!message) return;
      if (message.length > maxQuestionChars) return;
      const scope = currentScope();
      if (!scope) {
        updateQuestionState();
        return;
      }
      answerInFlight = true;
      updateQuestionState();
      hidePrompts();
      const questionWordCount = message.split(/\s+/).filter(Boolean).length;
      const questionSize = questionWordCount < 6 ? 'short' : questionWordCount < 18 ? 'medium' : 'long';
      const history = compactHistory(conversationHistory);
      const userMessage = addMessage('user', `<p>${escapeHtml(message)}</p>`);
      addShareControls(userMessage, message, scope);
      questionInput.value = '';
      updateQuestionState();
      const pending = addMessage('assistant', '<p class="librarian-status-line"><span class="librarian-thinking-dot"></span>Thingy is looking through the archive...</p>');
      pending.classList.add('librarian-message-pending');
      try {
        const data = await postStreamingChat(message, pending, history, scope);
        pending.classList.remove('librarian-message-pending');
        rememberTurn(message, data.answer || '');
        addFeedbackControls(pending, data.request_id);
        trackTinylyticsEvent('librarian.answer_success', `${questionSize}.${(data.citations || []).length}`);
      } catch (error) {
        pending.innerHTML = `<p>${escapeHtml(error.message)}</p>`;
        trackTinylyticsEvent('librarian.answer_error', error.requestId ? 'server' : 'client');
        if (/validate|subscriber/i.test(error.message)) {
          clearToken();
        }
      } finally {
        answerInFlight = false;
        updateQuestionState();
      }
    }

    questionForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      await submitQuestion();
    });

    questionInput.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' || event.shiftKey || event.altKey || event.ctrlKey || event.metaKey) return;
      event.preventDefault();
      questionForm.requestSubmit();
    });

    questionInput.addEventListener('input', updateQuestionState);

    scopeInputs.forEach((input) => {
      input.addEventListener('change', () => {
        activeScope = currentScope();
        trackTinylyticsEvent('librarian.scope_change', activeScope || 'none');
        updateQuestionState();
      });
    });

    prompts.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target : event.target.parentElement;
      const button = target ? target.closest('button[data-question]') : null;
      if (button) {
        questionInput.value = button.dataset.question;
        updateQuestionState();
        questionForm.requestSubmit();
      }
    });

    updateQuestionState();

    if (email) {
      window.localStorage.removeItem(storageKey);
      submitAuthCheck({ skipBetaNotice: Boolean(initialPrompt) });
      trackTinylyticsEvent('librarian.auth_auto_start');
    } else if (token()) {
      authPanel.hidden = true;
      chatPanel.hidden = false;
      loadPrompts();
      trackTinylyticsEvent('librarian.session_resume');
      maybeSubmitInitialPrompt();
    }
  })();
</script>

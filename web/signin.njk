---
layout: layouts/base.njk
permalink: /signin/
pageTitle: Sign In
description: Sign in to Thingy with a private email link.
---

<section class="thingy-auth-page">
  <div class="thingy-auth-card">
    <span class="thingy-auth-mark" aria-hidden="true"><img src="/img/thingy.png?v={{ site.assetVersion }}" alt="" width="1022" height="1022" loading="eager"></span>
    <div class="thingy-auth-content">
      <p class="thingy-auth-kicker">Thingy access</p>
      <h1 class="thingy-auth-title">Sign in to Thingy</h1>
      <p class="thingy-auth-copy">Enter your email address and Thingy will send a private sign-in link. Weekly Thing readers can use Chat, and supporting members get the deeper features.</p>
      <form class="thingy-signin-form" id="thingy-signin-form">
        <label for="thingy-signin-email">Email address</label>
        <div class="thingy-signin-row">
          <input id="thingy-signin-email" name="email" type="email" autocomplete="email" inputmode="email" required placeholder="you@example.com">
          <button type="submit" id="thingy-signin-submit">Send Link</button>
        </div>
      </form>
      <p class="thingy-signin-message" id="thingy-signin-message" aria-live="polite"></p>
      <div class="thingy-signin-secondary" id="thingy-signin-secondary" hidden>
        <button type="button" id="thingy-signin-subscribe" hidden>Add Me to The Weekly Thing</button>
        <button type="button" id="thingy-signin-resend" hidden>Resend Confirmation</button>
      </div>
    </div>
  </div>
</section>

<script>
  window.ThingyConfig = {
    librarianApiUrl: "{{ site.librarianApiUrl }}"
  };
</script>
<script src="/js/thingy-session.js?v={{ site.assetVersion }}"></script>
<script src="/js/thingy-signin.js?v={{ site.assetVersion }}"></script>

